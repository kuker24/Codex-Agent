{
  "name": "ai-agent-hub",
  "version": "1.0.0",
  "description": "Local Codex launcher with tmux grid mode and native swarm desktop mode",
  "private": true,
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "swarm:start": "node server/swarm-server.js",
    "swarm:dev": "node --watch server/swarm-server.js",
    "swarm:app": "electron desktop/main.cjs",
    "test": "bash tests/run-smoke-tests.sh",
    "test:smoke": "bash tests/run-smoke-tests.sh"
  },
  "keywords": [
    "codex",
    "agent",
    "dashboard",
    "pty",
    "xterm"
  ],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "express": "^5.2.1",
    "node-pty": "^1.1.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "electron": "^41.0.3"
  }
}
